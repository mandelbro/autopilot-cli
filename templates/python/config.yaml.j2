# Autopilot Configuration — {{ project_name }}
# Generated by `autopilot init --type python`

project:
  name: "{{ project_name }}"
  type: "python"
  root: "{{ project_root }}"

scheduler:
  strategy: "interval"
  interval_seconds: 1800
  cycle_timeout_seconds: 7200
  agent_timeout_seconds: 900
  agent_timeouts: {}
  consecutive_timeout_limit: 2

usage_limits:
  daily_cycle_limit: 200
  weekly_cycle_limit: 1400
  max_agent_invocations_per_cycle: 40

agents:
  roles:
    - project-leader
    - engineering-manager
    - technical-architect
    - product-director
  models: {}
  max_turns: {}
  fallback_models: {}
  max_concurrent: 3

quality_gates:
  pre_commit: "uv run ruff check ."
  type_check: "uv run pyright"
  test: "uv run pytest"
  all: "uv run ruff check . && uv run pyright && uv run pytest"

enforcement:
  enabled: true
  categories:
    - duplication
    - conventions
    - overengineering
    - security
    - error_handling
    - dead_code
    - type_safety
    - test_quality
    - comments
    - deprecated
    - async_misuse

safety:
  auto_merge: true
  require_ci_pass: true
  require_review_approval: true
  max_files_per_commit: 100
  require_tests: true

approval:
  auto_approve_low_risk: true
  auto_approve_medium_risk: false
  require_approval_for_deletions: true
  require_approval_for_schema_changes: true

claude:
  # INTENTIONAL: Required for autonomous unattended Claude Code sessions.
  # Safety is enforced via task scoping, enforcement engine, quality gates, and CI review.
  extra_flags: "--dangerously-skip-permissions"
  mcp_config: ".mcp.json"
  claude_flow_version: "alpha"

git:
  base_branch: "main"
  branch_prefix: "feat/"
  branch_strategy: "batch"

deployment_monitoring:
  enabled: false
  render:
    api_key_env: "RENDER_API_KEY"
    poll_interval_seconds: 60
    deploy_timeout_seconds: 600
  health_check_interval_seconds: 300
