{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autopilot-cli/schemas/uat-result.schema.json",
  "title": "UAT Result",
  "description": "The result of running User Acceptance Testing against a completed task.",
  "type": "object",
  "required": ["task_id", "test_name", "status", "assertions", "spec_references"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "The task identifier under test (e.g., '042').",
      "pattern": "^[0-9]{3}(-[0-9]+)?$"
    },
    "test_name": {
      "type": "string",
      "description": "Name of the UAT test run."
    },
    "status": {
      "type": "string",
      "description": "Overall UAT result status.",
      "enum": ["pass", "fail", "error", "skip"]
    },
    "score": {
      "type": "number",
      "description": "Composite UAT score (0.0-1.0).",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the UAT was executed.",
      "format": "date-time"
    },
    "assertions": {
      "type": "array",
      "description": "Individual test assertions and their results.",
      "items": {
        "$ref": "#/definitions/Assertion"
      }
    },
    "spec_references": {
      "type": "array",
      "description": "Specification sections verified by this UAT run.",
      "items": {
        "$ref": "#/definitions/SpecReference"
      }
    },
    "categories": {
      "type": "object",
      "description": "Results grouped by test category.",
      "properties": {
        "acceptance": { "$ref": "#/definitions/CategoryResult" },
        "behavioral": { "$ref": "#/definitions/CategoryResult" },
        "compliance": { "$ref": "#/definitions/CategoryResult" },
        "ux": { "$ref": "#/definitions/CategoryResult" }
      }
    },
    "test_count": {
      "type": "integer",
      "description": "Total number of tests executed.",
      "minimum": 0
    },
    "pass_count": {
      "type": "integer",
      "description": "Number of tests that passed.",
      "minimum": 0
    },
    "fail_count": {
      "type": "integer",
      "description": "Number of tests that failed.",
      "minimum": 0
    },
    "skip_count": {
      "type": "integer",
      "description": "Number of tests that were skipped.",
      "minimum": 0
    },
    "overall_pass": {
      "type": "boolean",
      "description": "Whether the score meets the configured threshold."
    },
    "duration_seconds": {
      "type": "number",
      "description": "Total execution time in seconds.",
      "minimum": 0
    },
    "failures": {
      "type": "array",
      "description": "Detailed information about each test failure.",
      "items": {
        "$ref": "#/definitions/TestFailure"
      }
    }
  },
  "definitions": {
    "Assertion": {
      "type": "object",
      "description": "A single test assertion within a UAT run.",
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Descriptive name of the assertion."
        },
        "status": {
          "type": "string",
          "description": "Assertion result.",
          "enum": ["pass", "fail", "skip"]
        },
        "message": {
          "type": "string",
          "description": "Additional detail or failure message."
        },
        "category": {
          "type": "string",
          "description": "Test category this assertion belongs to.",
          "enum": ["acceptance", "behavioral", "compliance", "ux"]
        },
        "spec_reference": {
          "$ref": "#/definitions/SpecReference"
        }
      }
    },
    "SpecReference": {
      "type": "object",
      "description": "A reference to a specific requirement in a specification document.",
      "required": ["document", "section", "requirement", "verification_type"],
      "properties": {
        "document": {
          "type": "string",
          "enum": ["RFC", "Discovery", "UX Design"]
        },
        "section": {
          "type": "string"
        },
        "requirement": {
          "type": "string"
        },
        "verification_type": {
          "type": "string",
          "enum": ["functional", "behavioral", "compliance"]
        }
      }
    },
    "CategoryResult": {
      "type": "object",
      "description": "Aggregated results for a test category.",
      "required": ["category", "pass_rate"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["acceptance", "behavioral", "compliance", "ux"]
        },
        "pass_rate": {
          "type": "number",
          "description": "Percentage of tests passing in this category (0.0-1.0).",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "test_count": {
          "type": "integer",
          "minimum": 0
        },
        "pass_count": {
          "type": "integer",
          "minimum": 0
        },
        "fail_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "TestFailure": {
      "type": "object",
      "description": "Detailed information about a single test failure.",
      "required": ["test_name", "category"],
      "properties": {
        "test_name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": ["acceptance", "behavioral", "compliance", "ux"]
        },
        "spec_reference": {
          "$ref": "#/definitions/SpecReference"
        },
        "expected": {
          "type": "string",
          "description": "Expected value or behavior."
        },
        "actual": {
          "type": "string",
          "description": "Actual value or behavior observed."
        },
        "suggestion": {
          "type": "string",
          "description": "Suggested fix for the failure."
        }
      }
    }
  }
}
